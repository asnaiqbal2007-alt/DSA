#include <stdio.h>
#include <stdlib.h>

// Comparator for sorting by start time
int compare(const void *a, const void *b) {
    int *i1 = (int *)a;
    int *i2 = (int *)b;
    return i1[0] - i2[0];
}

int main() {
    int n;
    scanf("%d", &n);

    int intervals[n][2];
    for (int i = 0; i < n; i++) {
        scanf("%d %d", &intervals[i][0], &intervals[i][1]);
    }

    // Step 1: Sort intervals by start time
    qsort(intervals, n, sizeof(intervals[0]), compare);

    // Result array
    int result[n][2];
    int index = 0;

    // Initialize with first interval
    result[index][0] = intervals[0][0];
    result[index][1] = intervals[0][1];

    // Step 2: Merge intervals
    for (int i = 1; i < n; i++) {
        // If overlapping
        if (intervals[i][0] <= result[index][1]) {
            // Merge by updating end
            if (intervals[i][1] > result[index][1])
                result[index][1] = intervals[i][1];
        } else {
            // No overlap → new interval
            index++;
            result[index][0] = intervals[i][0];
            result[index][1] = intervals[i][1];
        }
    }

    // Print merged intervals
    for (int i = 0; i <= index; i++) {
        printf("%d %d\n", result[i][0], result[i][1]);
    }

    return 0;
}
