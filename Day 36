#include <stdio.h>
#include <stdlib.h>

int main()
{
    int n, m, i;
    scanf("%d", &n);

    int *queue = (int *)malloc(n * sizeof(int));

    int front = 0, rear = -1;

    // Enqueue n elements
    for(i = 0; i < n; i++)
    {
        int x;
        scanf("%d", &x);
        rear = (rear + 1) % n;
        queue[rear] = x;
    }

    // Number of dequeue operations
    scanf("%d", &m);

    // Perform dequeue
    for(i = 0; i < m; i++)
    {
        front = (front + 1) % n;
    }

    // Display circular queue
    int count = n;
    int index = front;

    for(i = 0; i < count; i++)
    {
        printf("%d ", queue[index]);
        index = (index + 1) % n;
    }

    free(queue);
    return 0;
}
