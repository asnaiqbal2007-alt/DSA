#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX 1000
#define LEN 50

// Comparator function for qsort
int compare(const void *a, const void *b) {
    return strcmp((char *)a, (char *)b);
}

int main() {
    int n;
    scanf("%d", &n);

    char names[MAX][LEN];

    // Input names
    for (int i = 0; i < n; i++) {
        scanf("%s", names[i]);
    }

    // Sort names
    qsort(names, n, sizeof(names[0]), compare);

    char winner[LEN];
    int maxVotes = 0;

    for (int i = 0; i < n; ) {
        int count = 1;

        // Count same names
        while (i + 1 < n && strcmp(names[i], names[i + 1]) == 0) {
            count++;
            i++;
        }

        // Update winner
        if (count > maxVotes) {
            maxVotes = count;
            strcpy(winner, names[i]);
        }
        // Tie case → lexicographically smaller (array already sorted)
        else if (count == maxVotes && strcmp(names[i], winner) < 0) {
            strcpy(winner, names[i]);
        }

        i++;
    }

    printf("%s %d\n", winner, maxVotes);

    return 0;
}
